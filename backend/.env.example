# ============================================================
# WhatsApp AI SaaS — Environment Variables
# Copy this to .env and fill in the values
# ============================================================

# Server
PORT=3001
NODE_ENV=production

# Security — generate strong random string
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# Claude AI (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api...

# Data storage — Railway volume mount path
DATA_PATH=/data

# CORS — your Railway app URL (fill after first deploy)
ALLOWED_ORIGINS=https://your-app.up.railway.app
